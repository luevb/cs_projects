@page "/menu/pizzas"
@using BlazorPizzeria.Models
@using BlazorPizzeria.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject CartService Cart
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    <MudText Typo="Typo.h4">🍕 Пицца</MudText>

    @if (pizzas == null)
    {
        <MudProgressCircular Indeterminate />
    }
    else if (!pizzas.Any())
    {
        <MudAlert Severity="Severity.Info">Пиццы временно отсутствуют.</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var pizza in pizzas)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="d-flex flex-column" Style="height: 100%">
                        @if (!string.IsNullOrEmpty(pizza.ImageUrl))
                        {
                            <MudCardMedia Image="@pizza.ImageUrl" Height="150" />
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@pizza.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Tertiary">@pizza.Description</MudText>
                            <MudText Typo="Typo.subtitle1" Class="mt-2">
                                @pizza.Price ₽
                                @if (pizza.IsVegetarian)
                                {
                                    <MudBadge Color="Color.Success" Class="ms-2">Вегетарианская</MudBadge>
                                }
                            </MudText>

                            <!-- Кнопочный счётчик -->
                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               Color="Color.Secondary"
                                               OnClick="() => DecrementQuantity(pizza.Id)" />
                                <MudText Typo="Typo.body1" Class="mx-2" Style="min-width: 30px; text-align: center;">
                                    @GetQuantity(pizza.Id)
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => IncrementQuantity(pizza.Id)" />
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       FullWidth="true"
                                       OnClick="() => AddToCart(pizza)">
                                В корзину
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Pizza> pizzas = new();
    private Dictionary<int, int> quantities = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        pizzas = await db.Pizzas.ToListAsync();

        foreach (var pizza in pizzas)
            quantities[pizza.Id] = 1;
    }

    private int GetQuantity(int id) => quantities.GetValueOrDefault(id, 1);

    private void IncrementQuantity(int id)
    {
        var current = GetQuantity(id);
        if (current < 99) quantities[id] = current + 1;
    }

    private void DecrementQuantity(int id)
    {
        var current = GetQuantity(id);
        if (current > 1) quantities[id] = current - 1;
    }

    private void AddToCart(Pizza pizza)
    {
        int qty = GetQuantity(pizza.Id);
        Cart.AddItem("Pizza", pizza.Id, pizza.Name, pizza.Price, qty);
        Snackbar.Add($"{pizza.Name} добавлена в корзину (x{qty})", Severity.Success);
    }
}