@page "/menu/drink"
@using BlazorPizzeria.Models
@using BlazorPizzeria.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject CartService Cart
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    <MudText Typo="Typo.h4">🥤 Напитки</MudText>

    @if (drinks == null)
    {
        <MudProgressCircular Indeterminate />
    }
    else if (!drinks.Any())
    {
        <MudAlert Severity="Severity.Info">Напитки временно отсутствуют.</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var drink in drinks)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="d-flex flex-column" Style="height: 100%">
                        @if (!string.IsNullOrEmpty(drink.ImageUrl))
                        {
                            <MudCardMedia Image="@drink.ImageUrl" Height="150" />
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@drink.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Tertiary">@drink.Description</MudText>
                            <MudText Typo="Typo.subtitle1" Class="mt-2">
                                @drink.Price ₽
                            </MudText>

                            <!-- Кнопочный счётчик -->
                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               Color="Color.Secondary"
                                               OnClick="() => DecrementQuantity(drink.Id)" />
                                <MudText Typo="Typo.body1" Class="mx-2" Style="min-width: 30px; text-align: center;">
                                    @GetQuantity(drink.Id)
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => IncrementQuantity(drink.Id)" />
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       FullWidth="true"
                                       OnClick="() => AddToCart(drink)">
                                В корзину
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<Drink> drinks = new();
    private Dictionary<int, int> quantities = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        drinks = await db.Drinks.ToListAsync();

        foreach (var drink in drinks)
            quantities[drink.Id] = 1;
    }

    private int GetQuantity(int id) => quantities.GetValueOrDefault(id, 1);

    private void IncrementQuantity(int id)
    {
        var current = GetQuantity(id);
        if (current < 99) quantities[id] = current + 1;
    }

    private void DecrementQuantity(int id)
    {
        var current = GetQuantity(id);
        if (current > 1) quantities[id] = current - 1;
    }

    private void AddToCart(Drink drink)
    {
        int qty = GetQuantity(drink.Id);
        Cart.AddItem("Drink", drink.Id, drink.Name, drink.Price, qty);
        Snackbar.Add($"{drink.Name} добавлен в корзину (x{qty})", Severity.Success);
    }
}