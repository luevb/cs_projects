@* Основной контейнер формы
<MudForm @ref="_form" Model="@_newUser" Validation="@(new UserValidator())" @bind-IsValid="_isFormValid">
    <MudText Typo="Typo.h6">Регистрация</MudText>
    <!-- Поля формы с привязкой к модели  -->
    <!-- "For" связывает поле со свойством модели, запуская валидацию -->
    <MudTextField @bind-Value="_newUser.Name" For="@(() => _newUser.Name)"
                  Label="Имя" Variant="Variant.Outlined" Margin="Margin.Dense" />
    <MudTextField @bind-Value="_newUser.Email" For="@(() => _newUser.Email)"
                  Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
    <MudTextField @bind-Value="_newUser.Age" For="@(() => _newUser.Age)"
                  Label="Возраст" Variant="Variant.Outlined" Margin="Margin.Dense" />
    <!-- Кнопка отправки блокируется, если форма невалидна -->
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               Disabled="@(!_isFormValid)" OnClick="@SubmitForm">Зарегистрироваться</MudButton>
</MudForm>

@code {
    // Модель для формы
    private class User { public string Name { get; set; } = ""; public string Email { get; set; } = ""; public int Age { get; set; } }
    private User _newUser = new(); // Экземпляр модели
    private MudForm? _form;        // Ссылка на форму для доступа к её состоянию
    private bool _isFormValid;     // Флаг, показывающий, валидна ли форма сейчас
    // Пример валидатора с FluentValidation
    public class UserValidator : AbstractValidator<User>
    {
        public UserValidator()
        {
            RuleFor(x => x.Name).NotEmpty().WithMessage("Имя не может быть пустым");
            RuleFor(x => x.Email).NotEmpty().EmailAddress().WithMessage("Введите корректный email");
            RuleFor(x => x.Age).InclusiveBetween(18, 99).WithMessage("Возраст должен быть от 18 до 99");
        }
    }
    private async Task SubmitForm()
    {
        await _form!.Validate();
        if (_isFormValid)
        {
            // Логика сохранения данных
        }
    }
} *@