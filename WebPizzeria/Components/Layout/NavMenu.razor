@using WebPizzeria.Services
@inject CartService Carta
@implements IDisposable

@code {
    protected override void OnInitialized()
    {
        Carta.OnChange += StateHasChanged;
    }
    
    public void Dispose()
    {
        Carta.OnChange -= StateHasChanged;
    }
}
<div class="nav-item px-3">
    <NavLink class="nav-link" href="/pizzas">
        <span class="bi bi-list-nested"></span> Меню
    </NavLink>
</div>
<div class="nav-item px-3">
    <NavLink class="nav-link" href="/cart">
        <span class="bi bi-cart"></span> Корзина
        @if (Carta.TotalCount > 0)
        {
            <span class="badge bg-danger ms-1">@Carta.TotalCount</span>
        }
    </NavLink>
</div>