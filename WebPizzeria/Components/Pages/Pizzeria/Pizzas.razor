@page "/"
@page "/pizzas"
@using WebPizzeria.Models
@using WebPizzeria.Services
@inject IPizzaRepository PizzaRepo
@inject CartService Carta


<h3>🍕 Наше меню</h3>
<div class="row">
    @foreach (var pizza in pizzas)
    {
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(pizza.ImageUrl))
                {
                    <img src="@pizza.ImageUrl" class="card-img-top" alt="@pizza.Name" style="height: 200px; object-fit: cover;">
                }
                <div class="card-body">
                    <h5 class="card-title">@pizza.Name</h5>
                    <p class="card-text">@pizza.Description</p>
                    <p><strong>@pizza.Price ₽</strong> (@pizza.Size)</p>
                    @if (pizza.IsVegetarian)
                    {
                        <span class="badge bg-success">Вегетарианская</span>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-primary" @onclick="() => AddToCart(pizza)">В корзину</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Pizza> pizzas = new();
    
    protected override async Task OnInitializedAsync()
    {
        pizzas = (await PizzaRepo.GetAllAsync()).ToList();
    }
    
    private void AddToCart(Pizza pizza)
    {
        Carta.AddItem(pizza.Id, pizza.Name, pizza.Price);
    }
}