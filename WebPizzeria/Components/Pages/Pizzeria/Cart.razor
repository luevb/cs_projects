@page "/cart"
@using WebPizzeria.Services
@inject CartService Carta
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components


<h3>🛒 Корзина</h3>

@if (Carta.Items.Count == 0)
{
    <p>Корзина пуста. <a href="/pizzas">Перейти к меню</a></p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Пицца</th><th>Цена</th><th>Кол-во</th><th>Сумма</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Carta.Items)
            {
                <tr>    
                    <td>@item.Name</td>
                    <td>@item.Price ₽</td>
                    <td>@item.Quantity</td>
                    <td>@(item.Price * item.Quantity) ₽</td>
                    <td><button class="btn btn-sm btn-danger" @onclick="() => Carta.RemoveItem(item.PizzaId)">Удалить</button></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr><th colspan="3">Итого:</th><th>@Carta.TotalPrice ₽</th><th></th></tr>
        </tfoot>
    </table>
    <button @onclick="@(() => Navigation.NavigateTo("/checkout"))">Оформить заказ</button>
}